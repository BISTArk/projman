{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ProjMan",
  "version": "1.3.0",
  "identifier": "com.bistark.projman",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ProjMan",
        "width": 1300,
        "height": 850,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgyQUE2NjMzMjY4MzZBMkYKUldRdmFvTW1NMmFxZ21xR2JTbFR6ZkFhYmtNMVhEeVMrZjFwT2VhcWpNT0xQMEw4cG5DLzE4dDEK",
      "endpoints": [
        "https://bistark.github.io/projman/update.json"
      ]
    }
  }
}
